<configuration>
  <system.webServer>
    <rewrite>
      <rules>

        <!-- API Proxy -->
        <rule name="FastAPI Proxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:8000/{R:1}" />
        </rule>

      </rules>
    </rewrite>
  </system.webServer>
</configuration>